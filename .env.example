# ===============================
# 秘書 AI エージェント環境設定
# ===============================
# このファイルを .env にコピーして、実際の設定値を入力してください
# .env ファイルは .gitignore に追加して、リポジトリに含めないようにしてください

# ===============================
# Gmail OAuth 2.0 認証設定
# ===============================
# gmail_refresh_token.json から取得した値を入力
GMAIL_REFRESH_TOKEN=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Gmail API スコープ（通常は変更不要）
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.modify

# ===============================
# Google Calendar 認証設定
# ===============================
# Service Account JSON（環境変数で指定する場合）
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# または Service Account JSON ファイルのパス
GOOGLE_SERVICE_ACCOUNT_FILE=config/service_account.json

# 対象ユーザーメールアドレス（デフォルト: k.kikuchi@rfp-inc.jp）
GOOGLE_TARGET_USER_EMAIL=k.kikuchi@rfp-inc.jp

# ===============================
# Anthropic API 設定
# ===============================
# Claude API キー
ANTHROPIC_API_KEY=

# ===============================
# 開発環境設定
# ===============================
# ログレベル
LOG_LEVEL=INFO

# Flask デバッグモード
FLASK_DEBUG=False

# ===============================
# 本番環境設定（Cloud Functions/Cloud Run）
# ===============================
# 本番環境では環境変数またはシークレット管理サービスを使用してください
# Google Cloud Secret Manager を使用する場合：
# - GMAIL_REFRESH_TOKEN
# - GMAIL_CLIENT_ID
# - GMAIL_CLIENT_SECRET
# - ANTHROPIC_API_KEY
